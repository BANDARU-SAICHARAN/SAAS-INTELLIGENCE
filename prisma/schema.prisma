generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Lead {
  id          String   @id @default(cuid())
  company     String
  website     String?
  industry    String?
  leadScore   Int
  status      String   @default("New")
  summary     String
  outreachTip String?
  createdAt   DateTime @default(now())
}